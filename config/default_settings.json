{
  "paths": {
    "temp_dir": "temp",
    "data_dir": "data",
    "database_path": "data/assistant.db",
    "logs_dir": "logs"
  },
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "chunk_size": 1024,
    "max_record_seconds": 12,
    "min_record_seconds": 0.8,
    "silence_duration_stop_sec": 1.0,
    "silence_threshold": 500,
    "input_device_name": "",
    "output_device_name": "",
    "input_gain": 1.0,
    "meter_good_level_min": 18,
    "meter_good_level_max": 75,
    "auto_input_gain_enabled": true,
    "auto_gain_target_rms": 2200,
    "max_auto_gain": 10.0,
    "no_signal_rms_threshold": 120,
    "microphone_enabled": true
  },
  "speech": {
    "whisper_model_size": "small",
    "whisper_compute_type": "int8",
    "whisper_model_path": "models/faster-whisper-small",
    "command_language": "ru",
    "fallback_to_auto_language": true
  },
  "search": {
    "index_batch_size": 1000,
    "app_match_threshold": 72,
    "file_match_threshold": 70,
    "max_candidates": 5,
    "priority_confident_score": 92,
    "usage_direct_open_score": 85
  },
  "search_modes": {
    "enable_deep_search_prompt": true,
    "allow_deep_search_after_prompt": true,
    "auto_deep_search": false,
    "fast_search_timeout_sec": 1.5
  },
  "temp_cleanup": {
    "delete_record_after_transcribe": false,
    "delete_old_temp_on_startup": true,
    "max_temp_age_hours": 24
  },
  "assistant": {
    "language": "ru",
    "announce_before_execution": true,
    "announce_after_execution": true,
    "debug_candidates": true,
    "activation_mode": "hotkey",
    "voice_activation_phrase": "ассистент",
    "comment_actions": true,
    "wake_engine": "vosk",
    "wake_vosk_model_path": "models/vosk-model-small-ru-0.22",
    "wake_vosk_sample_rate": 16000,
    "wake_vosk_block_size": 4000,
    "wake_check_interval_sec": 0.35,
    "wake_post_activation_cooldown_sec": 2.5,
    "enabled_plugins": [
      "filesystem",
      "web",
      "music",
      "dictation",
      "chat"
    ]
  },
  "priority_roots": {
    "cwd": true,
    "desktop": true,
    "documents": true,
    "downloads": true,
    "recent": true,
    "start_menu_user": true,
    "start_menu_common": true,
    "extra_paths": []
  },
  "background": {
    "enabled": true,
    "hotkey": "<ctrl>+<alt>+<space>",
    "double_press_cancels": true
  },
  "providers": {
    "default_web_search_provider": "browser_google",
    "default_youtube_provider": "youtube_search",
    "default_music_provider": "yandex_music",
    "supported_music_providers": [
      "yandex_music",
      "vk_music",
      "spotify",
      "youtube_music",
      "youtube"
    ]
  },
  "voice": {
    "enabled": true,
    "rate": 185,
    "volume": 1.0,
    "heartbeat_interval_sec": 8,
    "voice_id": "",
    "voice_name": "",
    "phrases": {
      "listening": [
        "Слушаю.",
        "Говорите.",
        "Я слушаю."
      ],
      "processing": [
        "Обрабатываю запрос.",
        "Секунду, разбираюсь.",
        "Проверяю команду."
      ],
      "working": [
        "Я ещё работаю.",
        "Запрос ещё выполняется.",
        "Почти готово, продолжаю."
      ],
      "done": [
        "Готово.",
        "Выполнено.",
        "Команда выполнена."
      ],
      "like": [
        "Учту, это вам подошло.",
        "Принято, запомню как удачный вариант."
      ],
      "dislike": [
        "Понял, это вам не подошло.",
        "Принято, учту как неудачный вариант."
      ]
    }
  },
  "ui": {
    "hide_window_on_startup": false,
    "show_system_tabs": false
  },
  "startup": {
    "run_with_system": false
  },
  "ai": {
    "provider": "stub",
    "enabled": true,
    "apply_to_all_commands": true,
    "refine_dictation": true,
    "command_refine_timeout_sec": 4,
    "speak_responses": true,
    "provider_endpoint": "",
    "api_key": "",
    "remote_model": "",
    "remote_chat_model": "",
    "ollama_host": "http://localhost:11434",
    "ollama_model": "gemma3:4b",
    "chat_ollama_model": "gemma3:4b",
    "ollama_models_path": "",
    "wake_phrases": [
      "ассистент",
      "режим общения",
      "включи режим общения",
      "давай поговорим"
    ],
    "stop_phrases": [
      "выключи режим общения",
      "хватит общаться",
      "режим общения выключить",
      "заверши общение"
    ]
  }
}