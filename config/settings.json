{
  "paths": {
    "temp_dir": "temp",
    "data_dir": "data",
    "database_path": "data/assistant.db"
  },
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "chunk_size": 1024,
    "max_record_seconds": 12,
    "min_record_seconds": 0.8,
    "silence_duration_stop_sec": 1.0,
    "silence_threshold": 500
  },
  "background": {
    "enabled": true,
    "hotkey": "<ctrl>+<alt>+<space>",
    "double_press_cancels": true
  },
  "speech": {
    "whisper_model_size": "small",
    "whisper_compute_type": "int8"
  },
  "search": {
    "app_match_threshold": 78,
    "file_match_threshold": 78,
    "index_batch_size": 500,
    "max_candidates": 10,
    "priority_confident_score": 86,
    "usage_direct_open_score": 92
  },
  "search_modes": {
    "fast_search_timeout_sec": 1.5,
    "allow_deep_search_after_prompt": true,
    "auto_deep_search": false
  },
  "temp_cleanup": {
    "delete_record_after_transcribe": true,
    "delete_old_temp_on_startup": true,
    "max_temp_age_hours": 24
  },
  "priority_roots": {
    "cwd": true,
    "desktop": true,
    "documents": true,
    "downloads": true,
    "recent": true,
    "start_menu_user": true,
    "start_menu_common": true,
    "extra_paths": [
      "C:\\ProgramData\\Microsoft\\Windows\\Start Menu\\Programs",
      "C:\\Program Files",
      "C:\\Program Files (x86)",
      "C:\\Users\\druzh\\OneDrive\\Рабочий стол",
      "Документы",
      "C:\\",
      "Загрузки"
    ]
  },
  "assistant": {
    "announce_before_execution": true,
    "announce_after_execution": true,
    "debug_candidates": true
  },
  "providers": {
    "default_music_provider": "yandex_music",
    "supported_music_providers": [
      "yandex_music",
      "vk_music",
      "spotify",
      "youtube_music",
      "youtube"
    ]
  },
  "voice": {
    "enabled": false,
    "rate": 185,
    "volume": 1.0,
    "heartbeat_interval_sec": 8,
    "phrases": {
      "listening": [
        "Слушаю.",
        "Говорите.",
        "Я слушаю."
      ],
      "processing": [
        "Обрабатываю запрос.",
        "Секунду, разбираюсь.",
        "Проверяю команду."
      ],
      "working": [
        "Я ещё работаю.",
        "Запрос ещё выполняется.",
        "Почти готово, продолжаю."
      ],
      "done": [
        "Готово.",
        "Выполнено.",
        "Команда выполнена."
      ],
      "like": [
        "Учту, это вам подошло.",
        "Принято, запомню как удачный вариант."
      ],
      "dislike": [
        "Понял, это вам не подошло.",
        "Принято, учту как неудачный вариант."
      ]
    }
  }
}